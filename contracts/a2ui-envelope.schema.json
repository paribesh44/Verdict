{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://Verdict.dev/contracts/a2ui-envelope.schema.json",
  "title": "A2UIEnvelope",
  "oneOf": [
    { "$ref": "#/$defs/surfaceUpdateEnvelope" },
    { "$ref": "#/$defs/dataModelUpdateEnvelope" },
    { "$ref": "#/$defs/beginRenderingEnvelope" }
  ],
  "$defs": {
    "binding": {
      "type": "object",
      "required": ["prop", "path"],
      "properties": {
        "prop": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "surfaceComponent": {
      "type": "object",
      "required": ["id", "component"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "component": { "type": "string", "minLength": 1 },
        "props": { "type": "object", "additionalProperties": true },
        "bindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/binding" }
        }
      },
      "additionalProperties": false
    },
    "dataUpdate": {
      "type": "object",
      "required": ["path", "op", "value"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "op": { "type": "string", "enum": ["replace", "append", "merge"] },
        "value": {}
      },
      "additionalProperties": false
    },
    "baseEnvelope": {
      "type": "object",
      "required": ["requestId", "timestamp", "type"],
      "properties": {
        "requestId": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "surfaceUpdateEnvelope": {
      "allOf": [
        { "$ref": "#/$defs/baseEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "surfaceUpdate" },
            "components": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/surfaceComponent" }
            }
          },
          "required": ["components"]
        }
      ]
    },
    "dataModelUpdateEnvelope": {
      "allOf": [
        { "$ref": "#/$defs/baseEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "dataModelUpdate" },
            "updates": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/dataUpdate" }
            }
          },
          "required": ["updates"]
        }
      ]
    },
    "beginRenderingEnvelope": {
      "allOf": [
        { "$ref": "#/$defs/baseEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "beginRendering" },
            "surfaceId": { "type": "string", "minLength": 1 }
          },
          "required": ["surfaceId"]
        }
      ]
    }
  }
}
